WEBGAL_FRONTEND_URL=https://your-domain.example.com
BACKEND_PORT=8010
FRONTEND_PORT=3001

DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
ARK_API_KEY=
ARK_IMAGE_MODEL=doubao-seedream-4-5-251128

# If you have a real mp3 sound-effects directory on the server, point both vars to it.
# Example:
# WEBGAL_SOUND_EFFECTS_DIR=/opt/forge/sound-effects
# WEBGAL_SOUND_EFFECTS_DIR_HOST=/srv/webgal-forge/sound-effects
WEBGAL_SOUND_EFFECTS_DIR=/opt/forge/sound-effects
WEBGAL_SOUND_EFFECTS_DIR_HOST=./deploy/sound-effects

