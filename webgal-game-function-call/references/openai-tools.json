{
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "emit_narrative_plan",
        "description": "Return the complete narrative architecture for a WebGAL visual novel.",
        "strict": true,
        "parameters": {
          "type": "object",
          "required": ["narrative_plan"],
          "additionalProperties": false,
          "properties": {
            "narrative_plan": {
              "$ref": "schemas/narrative_plan.schema.json"
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "emit_asset_manifest",
        "description": "Return the complete generated-image manifest derived from the narrative plan.",
        "strict": true,
        "parameters": {
          "type": "object",
          "required": ["asset_manifest"],
          "additionalProperties": false,
          "properties": {
            "asset_manifest": {
              "$ref": "schemas/asset_manifest.schema.json"
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "emit_scene_batch",
        "description": "Return validated WebGAL scene file contents as data, not direct file writes.",
        "strict": true,
        "parameters": {
          "type": "object",
          "required": ["scene_batch"],
          "additionalProperties": false,
          "properties": {
            "scene_batch": {
              "$ref": "schemas/scene_batch.schema.json"
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "emit_validation_report",
        "description": "Return a structured validation report for a generated WebGAL game.",
        "strict": true,
        "parameters": {
          "type": "object",
          "required": ["validation_report"],
          "additionalProperties": false,
          "properties": {
            "validation_report": {
              "$ref": "schemas/validation_report.schema.json"
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "emit_repair_plan",
        "description": "Return targeted scene-file repairs for validation errors.",
        "strict": true,
        "parameters": {
          "type": "object",
          "required": ["repair_plan"],
          "additionalProperties": false,
          "properties": {
            "repair_plan": {
              "$ref": "schemas/repair_plan.schema.json"
            }
          }
        }
      }
    }
  ]
}
