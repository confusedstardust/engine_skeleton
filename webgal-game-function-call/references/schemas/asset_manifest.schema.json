{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "asset_manifest.schema.json",
  "title": "WebGAL Asset Manifest",
  "type": "object",
  "required": ["base_dir", "model", "images"],
  "additionalProperties": false,
  "properties": {
    "base_dir": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["filename", "subdir", "size", "prompt"],
        "additionalProperties": false,
        "properties": {
          "filename": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "subdir": { "type": "string", "minLength": 1 },
          "size": { "type": "string", "minLength": 1 },
          "prompt": { "type": "string", "minLength": 20 },
          "available_scene": { "type": "string", "minLength": 0 }
        }
      }
    }
  }
}
