{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "narrative_plan.schema.json",
  "title": "WebGAL Narrative Plan",
  "type": "object",
  "required": ["metadata", "characters", "variables", "scenes", "connections", "branches", "endings"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["title", "premise", "tone", "source_summary"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "premise": { "type": "string", "minLength": 1 },
        "tone": { "type": "string", "minLength": 1 },
        "source_summary": { "type": "string", "minLength": 1 }
      }
    },
    "characters": {
      "type": "array",
      "minItems": 3,
      "maxItems": 7,
      "items": {
        "type": "object",
        "required": ["id", "name", "role", "personality", "motivation", "internal_conflict", "speech_style", "emotional_arc", "relationships"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "name": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "enum": ["protagonist", "supporting", "antagonist", "catalyst", "chorus"] },
          "personality": { "type": "string", "minLength": 1 },
          "motivation": { "type": "string", "minLength": 1 },
          "internal_conflict": { "type": "string", "minLength": 1 },
          "speech_style": { "type": "string", "minLength": 1 },
          "emotional_arc": { "type": "string", "minLength": 1 },
          "relationships": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["with_character_id", "dynamic"],
              "additionalProperties": false,
              "properties": {
                "with_character_id": { "$ref": "#/$defs/id" },
                "dynamic": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "variables": {
      "type": "object",
      "required": ["attitude", "flags"],
      "additionalProperties": false,
      "properties": {
        "attitude": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "object",
            "required": ["id", "description", "default", "min", "max"],
            "additionalProperties": false,
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "description": { "type": "string", "minLength": 1 },
              "default": { "type": "integer", "minimum": 0, "maximum": 100 },
              "min": { "type": "integer", "const": 0 },
              "max": { "type": "integer", "const": 100 }
            }
          }
        },
        "flags": {
          "type": "array",
          "maxItems": 15,
          "items": {
            "type": "object",
            "required": ["id", "description", "default", "values"],
            "additionalProperties": false,
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "description": { "type": "string", "minLength": 1 },
              "default": { "type": "integer", "const": 0 },
              "values": {
                "type": "array",
                "items": { "type": "integer", "enum": [0, 1] },
                "minItems": 2,
                "maxItems": 2
              }
            }
          }
        }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 5,
      "maxItems": 25,
      "items": {
        "type": "object",
        "required": ["id", "file", "title", "act", "description", "purpose", "is_entry", "is_ending", "characters_present"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "file": { "$ref": "#/$defs/scene_file" },
          "title": { "type": "string", "minLength": 1 },
          "act": { "type": "integer", "minimum": 0, "maximum": 9 },
          "description": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "is_entry": { "type": "boolean" },
          "is_ending": { "type": "boolean" },
          "characters_present": {
            "type": "array",
            "items": { "$ref": "#/$defs/id" }
          }
        }
      }
    },
    "connections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from_scene_id", "to_scene_id", "kind", "condition"],
        "additionalProperties": false,
        "properties": {
          "from_scene_id": { "$ref": "#/$defs/id" },
          "to_scene_id": { "$ref": "#/$defs/id" },
          "kind": { "type": "string", "enum": ["callScene", "choose_option", "ending_jump"] },
          "condition": {
            "type": ["string", "null"],
            "description": "Single WebGAL condition expression or null."
          }
        }
      }
    },
    "branches": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["id", "scene_id", "description", "depth", "options"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "scene_id": { "$ref": "#/$defs/id" },
          "description": { "type": "string", "minLength": 1 },
          "depth": { "type": "integer", "minimum": 1, "maximum": 2 },
          "options": {
            "type": "array",
            "minItems": 3,
            "maxItems": 4,
            "items": {
              "type": "object",
              "required": ["label", "sets", "adds", "next_scene_id", "unique_beat"],
              "additionalProperties": false,
              "properties": {
                "label": { "type": "string", "minLength": 1 },
                "sets": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/variable_assignment" }
                },
                "adds": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/variable_assignment" }
                },
                "next_scene_id": { "$ref": "#/$defs/id" },
                "unique_beat": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "endings": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "file", "category", "priority", "emotional_tone", "trigger", "narrative_meaning"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "file": { "$ref": "#/$defs/scene_file" },
          "category": { "type": "string", "enum": ["best", "emotional", "character", "failure", "default"] },
          "priority": { "type": "integer", "minimum": 1, "maximum": 5 },
          "emotional_tone": { "type": "string", "minLength": 1 },
          "trigger": {
            "type": "object",
            "required": ["type", "conditions", "required_count"],
            "additionalProperties": false,
            "properties": {
              "type": { "type": "string", "enum": ["accumulator", "single_flag", "threshold", "fallback"] },
              "conditions": {
                "type": "array",
                "items": { "$ref": "#/$defs/condition" }
              },
              "required_count": { "type": ["integer", "null"], "minimum": 1 }
            }
          },
          "narrative_meaning": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "scene_file": { "type": "string", "pattern": "^[a-z][a-z0-9_]+\\.txt$" },
    "variable_assignment": {
      "type": "object",
      "required": ["variable_id", "value"],
      "additionalProperties": false,
      "properties": {
        "variable_id": { "$ref": "#/$defs/id" },
        "value": { "type": "integer" }
      }
    },
    "condition": {
      "type": "object",
      "required": ["variable_id", "operator", "value"],
      "additionalProperties": false,
      "properties": {
        "variable_id": { "$ref": "#/$defs/id" },
        "operator": { "type": "string", "enum": [">=", ">", "==", "<=", "<"] },
        "value": { "type": "integer" }
      }
    }
  }
}
