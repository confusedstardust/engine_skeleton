{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repair_plan.schema.json",
  "title": "WebGAL Repair Plan",
  "type": "object",
  "required": ["cycle", "repairs", "unfixable"],
  "additionalProperties": false,
  "properties": {
    "cycle": { "type": "integer", "minimum": 1, "maximum": 3 },
    "repairs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue_code", "file", "strategy", "find", "replace", "rationale"],
        "additionalProperties": false,
        "properties": {
          "issue_code": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "file": { "type": "string", "pattern": "^public/game/scene/[a-z][a-z0-9_]+\\.txt$" },
          "strategy": { "type": "string", "enum": ["replace_text", "insert_after", "insert_before", "append_block", "manual_required"] },
          "find": { "type": ["string", "null"] },
          "replace": { "type": ["string", "null"] },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    "unfixable": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue_code", "file", "reason"],
        "additionalProperties": false,
        "properties": {
          "issue_code": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "file": { "type": ["string", "null"] },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
