{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scene_batch.schema.json",
  "title": "WebGAL Scene Batch",
  "type": "object",
  "required": ["scenes"],
  "additionalProperties": false,
  "properties": {
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
          "required": ["scene_id", "file", "referenced_assets", "referenced_variables", "background_asset", "speaker_character_id", "beats"],
          "additionalProperties": false,
          "properties": {
            "scene_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
            "file": { "type": "string", "pattern": "^[a-z][a-z0-9_]+\\.txt$" },
            "referenced_assets": {
              "type": "array",
              "items": { "type": "string", "pattern": "^(bg|figure|miniavatar|cg)_[a-z0-9_]+\\.(webp|mp3)$" }
            },
            "referenced_variables": {
              "type": "array",
              "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
            },
            "background_asset": { "type": "string", "pattern": "^(bg|cg)_[a-z0-9_]+\\.webp$" },
            "speaker_character_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
            "beats": {
              "type": "array",
              "minItems": 8,
              "maxItems": 18,
              "description": "Short narrative/dialogue beats. Backend renders them into WebGAL syntax.",
              "items": {
                "type": "object",
                "required": ["kind", "text"],
                "additionalProperties": false,
                "properties": {
                  "kind": { "type": "string", "enum": ["narration", "dialogue"] },
                  "text": { "type": "string", "minLength": 1, "maxLength": 180 }
                }
              }
            }
        }
      }
    }
  }
}
